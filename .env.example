
# --- FIREBASE CONFIGURATION ---
# VITE_FIREBASE_PROJECT_ID: The ID of your Firebase project.
VITE_FIREBASE_PROJECT_ID=""

# VITE_FIREBASE_APP_ID: The unique ID for your Firebase Web App.
VITE_FIREBASE_APP_ID=""

# VITE_FIREBASE_API_KEY: The public API key used to identify your project to Google servers.
VITE_FIREBASE_API_KEY=""

# VITE_FIREBASE_AUTH_DOMAIN: The auth domain used by Firebase Authentication.
VITE_FIREBASE_AUTH_DOMAIN=""

# VITE_FIREBASE_STORAGE_BUCKET: Your project's Google Cloud Storage bucket name.
