# VITE_FIREBASE_MESSAGING_SENDER_ID: Sender ID for Firebase Cloud Messaging (FCM).
VITE_FIREBASE_MESSAGING_SENDER_ID=""

# VITE_FIREBASE_MEASUREMENT_ID: Google Analytics Measurement ID (optional).
